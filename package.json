{
  "name": "genisys",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "version": ">=1.2.0"
    }
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "just dev",
    "build": "just build",
    "test": "vitest run --config src/apps/api/vitest.config.ts && vitest run --config src/apps/room-supervisor/vitest.config.ts && vitest run --config src/libs/agent-rooms-core/vitest.config.ts && vitest run --config src/libs/shared/vitest.config.ts && vitest run --config src/libs/logger/vitest.config.ts",
    "test:unit": "pnpm test",
    "test:web": "pnpm --filter @repo/web exec vitest run",
    "test:e2e": "just test-e2e",
    "lint": "eslint .",
    "typecheck": "pnpm --filter @repo/shared typecheck && pnpm --filter @repo/logger typecheck && pnpm --filter @repo/web typecheck",
    "typecheck:api": "pnpm --filter @repo/api typecheck",
    "start": "node src/apps/api/dist/index.js",
    "clean": "node -e \"const fs=require('fs');const paths=['src/apps/api/dist','src/apps/room-supervisor/dist','src/apps/web/.output','src/libs/agent-rooms-core/dist','src/libs/shared/dist','src/libs/logger/dist','.turbo','node_modules/.cache'];for(const p of paths){try{fs.rmSync(p,{recursive:true,force:true});}catch{}}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "workspaces": {
    "packages": [
      "src/apps/*",
      "src/libs/*",
      "src/tooling/*",
      "tools/*",
      "e2e"
    ],
    "catalog": {
      "@fastify/cors": "^10.0.1",
      "@fastify/helmet": "^12.0.1",
      "@fastify/rate-limit": "^10.2.1",
      "@fastify/websocket": "^11.0.1",
      "@iconify-json/lucide": "^1.2.103",
      "@mariozechner/pi-ai": "^0.73.1",
      "@mariozechner/pi-coding-agent": "^0.73.1",
      "@nuxt/ui": "^4.7.0",
      "@octokit/rest": "^21.1.1",
      "@playwright/test": "^1.49.0",
      "@types/better-sqlite3": "^7.6.13",
      "@types/node": "22.19.15",
      "@typescript-eslint/eslint-plugin": "^8.18.0",
      "@typescript-eslint/parser": "^8.18.0",
      "@vitejs/plugin-vue": "^5.2.4",
      "@vitest/coverage-v8": "^2.1.8",
      "@vue/test-utils": "^2.4.8",
      "@vue/language-core": "^3.1.2",
      "better-sqlite3": "^12.9.0",
      "commander": "^14.0.3",
      "drizzle-kit": "^0.31.10",
      "drizzle-orm": "^0.45.2",
      "eslint": "^9.17.0",
      "eslint-plugin-import": "^2.32.0",
      "fast-glob": "^3.3.2",
      "fastify": "^5.1.0",
      "fastify-type-provider-zod": "^5.1.0",
      "happy-dom": "^15.11.7",
      "ignore": "^7.0.0",
      "nuxt": "^4.0.0",
      "pino": "^9.6.0",
      "prom-client": "^15.1.3",
      "tailwindcss": "^4.2.4",
      "tsup": "^8.3.5",
      "tsx": "^4.21.0",
      "typescript": "5.9.3",
      "typescript-eslint": "^8.18.0",
      "vitest": "2.1.9",
      "vue": "^3.5.31",
      "vue-tsc": "^3.1.2",
      "zod": "4.3.6"
    },
    "catalogs": {
      "legacy": {
        "commander": "^12.1.0"
      }
    }
  }
}
