{
  "name": "@repo/context-extractor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "context-extractor": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --target node22",
    "build:binary": "bun build --compile src/index.ts --outfile context-extractor",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  }
}
