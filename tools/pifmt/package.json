{
  "name": "@repo/pifmt",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "pifmt": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --target node22",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  }
}
